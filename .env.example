# Copy this file to .env and fill in the values.

# Mapbox public token — get yours at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Optional: override PVGIS base URL
# PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2

# Optional: override electricity price (EUR/kWh)
# DEFAULT_ELECTRICITY_PRICE_EUR=0.30
